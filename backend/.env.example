# ============================================================
# MedicGraph Backend — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual API keys:
#   cp .env.example .env
# ============================================================

# --- API Keys (Required) ---

# OpenRouter API key — used for OpenAI-compatible embedding requests
# Get one at: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Google Gemini API key — used for LLM inference
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy-your-gemini-key-here


# --- Model Configuration (Optional — defaults shown) ---

# EMBEDDING_MODEL=text-embedding-ada-002
# EMBEDDING_API_BASE=https://openrouter.ai/api/v1
# LLM_MODEL=gemini-2.5-flash


# --- Storage Configuration (Optional — defaults shown) ---

# CHROMA_PERSIST_DIR=./chroma_db
# UPLOAD_DIR=./uploads


# --- Chunking Configuration (Optional — defaults shown) ---

# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# RETRIEVER_K=5


# --- CORS Configuration (Optional — defaults shown) ---
# Comma-separated list of allowed origins
# CORS_ORIGINS=["http://localhost:3000"]
